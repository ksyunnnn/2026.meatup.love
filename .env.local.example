# Firebase Web config.
# NOTE: these are NOT secrets — they ship to the browser by design.
# Real protection comes from Firestore security rules, not from hiding these.
# Get real values from: Firebase console > Project settings > Your apps > Web app.
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# --- Local development with the Firebase Emulator Suite ---
# Set to "true" to route Auth/Firestore to the local emulators.
# For pure-emulator dev you can use a demo project (no real Firebase project needed):
#   NEXT_PUBLIC_FIREBASE_PROJECT_ID=demo-meatup
#   (the other NEXT_PUBLIC_FIREBASE_* may be any non-empty placeholder)
NEXT_PUBLIC_USE_EMULATOR=false
