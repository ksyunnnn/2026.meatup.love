rules_version = '2';

// ============================================================================
// DRAFT — starting point, not final. Tracks the current design (see
// docs/SPEC.md, which is itself an evolving roadmap). Known TODOs below.
//
// Model:
//  - attendees/{uid} : one per guest. status integrity is enforced here so a
//      guest can NEVER self-approve. "approved" at creation is allowed ONLY
//      when a valid invite token is presented (host-issued). Otherwise the
//      guest is created "pending" and a host confirms (UberEats-style).
//  - invites/{token} : host-issued invite links. Created by admins now;
//      later extendable to attendees holding an invite quota (FR9).
//  - admins/{uid}    : presence == admin. Managed out-of-band (console/tooling).
//
// TODO (later cycles):
//  - Marking an invite as used (usedBy) needs either a narrow rule letting the
//    consumer set it once, or privileged tooling. Not handled yet.
//  - ticketNo assignment/uniqueness strategy (random code vs counter).
//  - Tighten field-level validation once the form fields are finalized.
// ============================================================================

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn()
        && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    // A valid, not-yet-consumed invite for the given edition.
    function validInvite(token, edition) {
      return token is string
        && exists(/databases/$(database)/documents/invites/$(token))
        && get(/databases/$(database)/documents/invites/$(token)).data.edition == edition
        && !get(/databases/$(database)/documents/invites/$(token)).data.keys().hasAny(['usedBy']);
    }

    // A valid invite that was issued by a host (admin). Only these auto-confirm;
    // attendee-issued invites (FR9) record the referral but stay pending.
    function adminInvite(token, edition) {
      return validInvite(token, edition)
        && exists(/databases/$(database)/documents/admins/$(get(/databases/$(database)/documents/invites/$(token)).data.issuedBy));
    }

    // A confirmed (approved) attendee — may issue invites under FR9.
    function isApprovedAttendee(uid) {
      return exists(/databases/$(database)/documents/attendees/$(uid))
        && get(/databases/$(database)/documents/attendees/$(uid)).data.status == 'approved';
    }

    match /attendees/{uid} {
      allow read: if isSignedIn() && (request.auth.uid == uid || isAdmin());

      // Self-create. status integrity enforced here.
      allow create: if isSignedIn()
        && request.auth.uid == uid
        && request.resource.data.edition is string
        && request.resource.data.createdAt is timestamp
        && (
          // walk-in, or invited by a confirmed attendee (FR9): must start pending
          request.resource.data.status == 'pending'
          // host-invited: may start approved ONLY with a valid admin-issued token
          // that is ALSO consumed (usedBy == self) in this SAME commit. getAfter
          // binds the approval to the consumption, so one token can't auto-approve
          // more than one account and a direct write that skips consuming the
          // token (would leave it reusable) is rejected.
          || (request.resource.data.status == 'approved'
              && adminInvite(request.resource.data.inviteToken, request.resource.data.edition)
              && getAfter(/databases/$(database)/documents/invites/$(request.resource.data.inviteToken)).data.usedBy == request.auth.uid)
        );

      // Self-update: edit own profile fields, but NOT status or ticketNo.
      allow update: if isSignedIn()
        && request.auth.uid == uid
        && request.resource.data.status == resource.data.status
        && request.resource.data.ticketNo == resource.data.ticketNo;

      // Host: approve/reject and assign ticketNo.
      allow update: if isAdmin();

      allow delete: if isAdmin();
    }

    match /invites/{token} {
      // Signed-in users may read to validate an invite at registration time.
      allow read: if isSignedIn();
      // FR9: admins (unlimited) and confirmed attendees may issue invites,
      // always as themselves. The per-attendee quota is UI-soft (rules can't
      // count); attendee-issued invites don't auto-confirm, so it isn't a
      // security boundary.
      allow create: if (isAdmin() || isApprovedAttendee(request.auth.uid))
        && request.resource.data.issuedBy == request.auth.uid;
      // Consume once: a signed-in user may set usedBy to themselves on an
      // unused invite, touching no other field. Enforces single-use.
      allow update: if isSignedIn()
        && !('usedBy' in resource.data)
        && request.resource.data.usedBy == request.auth.uid
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['usedBy']);
      allow update, delete: if isAdmin();
    }

    // Public, minimal projection for OG image generation. World-readable on
    // purpose (used by the unauthenticated share/OG edge function); only the
    // owner may write their own, and only this allow-listed set of fields.
    // role + expectations drive the personalized ticket art; gender is NOT
    // here on purpose (sensitive, not shown on the shared ticket).
    match /shares/{uid} {
      allow read: if true;
      function sharesFieldsOk() {
        return request.resource.data.keys()
          .hasOnly(['name', 'ticketNo', 'edition', 'role', 'expectations']);
      }
      // Owner-only; only allow-listed fields; ticketNo is fixed once written
      // (name may change later for display, but the number can't be forged).
      allow create: if isSignedIn()
        && request.auth.uid == uid
        && sharesFieldsOk()
        && request.resource.data.name is string
        && request.resource.data.ticketNo is string;
      allow update: if isSignedIn()
        && request.auth.uid == uid
        && sharesFieldsOk()
        && request.resource.data.ticketNo == resource.data.ticketNo;
    }

    match /admins/{uid} {
      // A user may check their OWN admin status; admins may read any.
      allow read: if isSignedIn() && (request.auth.uid == uid || isAdmin());
      allow write: if false; // set via console / privileged tooling only
    }
  }
}
