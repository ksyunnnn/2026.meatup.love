rules_version = '2';

// ============================================================================
// DRAFT — starting point, not final. Tracks the current design (see
// docs/SPEC.md, which is itself an evolving roadmap). Known TODOs below.
//
// Model:
//  - attendees/{uid} : one per guest. status integrity is enforced here so a
//      guest can NEVER self-approve. "approved" at creation is allowed ONLY
//      when a valid invite token is presented (host-issued). Otherwise the
//      guest is created "pending" and a host confirms (UberEats-style).
//  - invites/{token} : host-issued invite links. Created by admins now;
//      later extendable to attendees holding an invite quota (FR9).
//  - admins/{uid}    : presence == admin. Managed out-of-band (console/tooling).
//
// TODO (later cycles):
//  - Marking an invite as used (usedBy) needs either a narrow rule letting the
//    consumer set it once, or privileged tooling. Not handled yet.
//  - ticketNo assignment/uniqueness strategy (random code vs counter).
//  - Tighten field-level validation once the form fields are finalized.
// ============================================================================

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn()
        && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    // A valid, not-yet-consumed invite for the given edition.
    function validInvite(token, edition) {
      return token is string
        && exists(/databases/$(database)/documents/invites/$(token))
        && get(/databases/$(database)/documents/invites/$(token)).data.edition == edition
        // Match the consume rule's form ('usedBy' in data) so the two stay
        // consistent and a future deleteField('usedBy') reset can't reopen it.
        && !('usedBy' in get(/databases/$(database)/documents/invites/$(token)).data);
    }

    // A valid invite that was issued by a host (admin). Only these auto-confirm;
    // attendee-issued invites (FR9) record the referral but stay pending.
    function adminInvite(token, edition) {
      return validInvite(token, edition)
        && exists(/databases/$(database)/documents/admins/$(get(/databases/$(database)/documents/invites/$(token)).data.issuedBy));
    }

    // A confirmed (approved) attendee — may issue invites under FR9.
    function isApprovedAttendee(uid) {
      return exists(/databases/$(database)/documents/attendees/$(uid))
        && get(/databases/$(database)/documents/attendees/$(uid)).data.status == 'approved';
    }

    match /attendees/{uid} {
      allow read: if isSignedIn() && (request.auth.uid == uid || isAdmin());

      // Self-create. status integrity enforced here.
      allow create: if isSignedIn()
        && request.auth.uid == uid
        && request.resource.data.edition is string
        && request.resource.data.createdAt is timestamp
        && (
          // walk-in, or invited by a confirmed attendee (FR9): must start pending
          request.resource.data.status == 'pending'
          // host-invited: may start approved ONLY with a valid admin-issued token
          // that is ALSO consumed (usedBy == self) in this SAME commit. getAfter
          // binds the approval to the consumption, so one token can't auto-approve
          // more than one account and a direct write that skips consuming the
          // token (would leave it reusable) is rejected.
          || (request.resource.data.status == 'approved'
              && adminInvite(request.resource.data.inviteToken, request.resource.data.edition)
              && getAfter(/databases/$(database)/documents/invites/$(request.resource.data.inviteToken)).data.usedBy == request.auth.uid)
        );

      // Self-update: a guest may edit ONLY their own profile/contact fields.
      // Whitelisting the touchable keys (not just pinning status/ticketNo) stops
      // a guest from writing host-controlled fields via a raw updateDoc — most
      // importantly `paid`/`paidAt` (the host marks payment off-app; self-set
      // would let someone attend unpaid), plus `gender`/`approvedAt`/
      // `approvedBy`/`inviteToken` audit fields.
      allow update: if isSignedIn()
        && request.auth.uid == uid
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
             'name', 'job', 'jobOther', 'expectations',
             'contactMethod', 'contactValue',
             'withKids', 'hasAllergy', 'allergyNote'
           ]);

      // Host: approve/reject and assign ticketNo.
      allow update: if isAdmin();

      // Host adds a guest manually (someone who contacted them directly and
      // won't self-register). These docs use a synthetic `manual_*` id, never a
      // real auth uid, so no signed-in user can own one. Admins are trusted, so
      // the field/status integrity enforced on self-create doesn't apply here.
      allow create: if isAdmin();

      allow delete: if isAdmin();
    }

    match /invites/{token} {
      // Signed-in users may read to validate an invite at registration time.
      allow read: if isSignedIn();
      // FR9: admins (unlimited) and confirmed attendees may issue invites,
      // always as themselves. The per-attendee quota is UI-soft (rules can't
      // count); attendee-issued invites don't auto-confirm, so it isn't a
      // security boundary.
      allow create: if (isAdmin() || isApprovedAttendee(request.auth.uid))
        && request.resource.data.issuedBy == request.auth.uid;
      // Consume once: a signed-in user may set usedBy to themselves on an
      // unused invite, touching no other field. Enforces single-use.
      allow update: if isSignedIn()
        && !('usedBy' in resource.data)
        && request.resource.data.usedBy == request.auth.uid
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['usedBy']);
      allow update, delete: if isAdmin();
    }

    // Public, minimal projection for OG image generation. World-readable on
    // purpose (used by the unauthenticated share/OG edge function); only the
    // owner may write their own, and only this allow-listed set of fields.
    // role + expectations drive the personalized ticket art; gender is NOT
    // here on purpose (sensitive, not shown on the shared ticket).
    match /shares/{uid} {
      allow read: if true;
      function sharesFieldsOk() {
        return request.resource.data.keys()
          .hasOnly(['name', 'ticketNo', 'edition', 'role', 'expectations']);
      }
      // Owner-only; only allow-listed fields; ticketNo is fixed once written
      // (name may change later for display, but the number can't be forged).
      // The public ticketNo must match the owner's real attendees record —
      // shares is always created in the same transaction as attendees/{uid}
      // (see createAttendee), so getAfter sees the co-written attendee. This
      // stops a guest from publishing a fabricated ticket number.
      allow create: if isSignedIn()
        && request.auth.uid == uid
        && sharesFieldsOk()
        && request.resource.data.name is string
        && request.resource.data.ticketNo is string
        && request.resource.data.ticketNo
             == getAfter(/databases/$(database)/documents/attendees/$(uid)).data.ticketNo;
      allow update: if isSignedIn()
        && request.auth.uid == uid
        && sharesFieldsOk()
        && request.resource.data.ticketNo == resource.data.ticketNo;
      // Host deletes a guest from /admin: the attendee doc and this public
      // projection are removed together, so the deleted guest's OG card stops
      // resolving. Owner can't delete their own (no self-delete path needed).
      allow delete: if isAdmin();
    }

    // Public aggregate for the homepage "Data" section. World-readable on
    // purpose: it holds ONLY anonymous numbers (total / gender counts / job &
    // expectation tallies) computed by an admin from the full roster — never
    // PII, never per-person rows. Only admins write it (recomputed from /admin),
    // so a guest can't forge the public figures.
    match /stats/{edition} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ========================================================================
    // 会場交流ポイントゲーム「繋がりレース」（see issue #11 for the full spec）
    // ========================================================================

    // connections/{pairId} : one undirected edge per pair of guests. pairId is
    // the two uids sorted and joined with '__' (see lib/game.connectionId), so a
    // pair can exist at most once — a repeat write lands as an UPDATE (there is
    // no update rule) and is denied. That is how "1ペア1回" (no point farming)
    // is enforced in the rules layer, not just the UI. World-readable: the
    // projector draws the live graph unauthenticated, and the live score is the
    // connection COUNT only — it never reveals who is a hidden special. An edge
    // is created by ONE of its two participants, recorded as themselves (`by`).
    match /connections/{pairId} {
      allow read: if true;
      allow create: if isSignedIn()
        && request.resource.data.a is string
        && request.resource.data.b is string
        && request.resource.data.a < request.resource.data.b
        && pairId == request.resource.data.a + '__' + request.resource.data.b
        && (request.auth.uid == request.resource.data.a
            || request.auth.uid == request.resource.data.b)
        && request.resource.data.by == request.auth.uid
        && request.resource.data.edition is string
        && request.resource.data.createdAt is timestamp;
      // No update path (dedup, above). Admin deletes when removing a guest.
      allow delete: if isAdmin();
    }

    // specials/{uid} : which guests award bonus points, and how many.
    // `public:true` = staff (glows on the projector); `public:false` = a hidden
    // special that looks like any normal node. A single-doc get() is open to
    // signed-in users so a scanner can resolve a partner they physically met
    // (the ✨ reveal on their own phone); list() is admin-only so nobody can
    // enumerate the hidden specials (accidental exposure is impossible; a
    // deliberate per-uid probe is out of scope under the game's 性善説 model).
    match /specials/{uid} {
      allow get: if isSignedIn();
      allow list: if isAdmin();
      allow write: if isAdmin();
    }

    // control/{edition} : live game + projector display state, driven by the
    // host from /control (game: open|closed, ranking: shown|mosaic, reveal:
    // bump-to-replay). World-readable — the projector listens and phones read it
    // to know when scanning has closed. Admin-only write.
    match /control/{edition} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // results/{edition} : the final ranking (connection count + special
    // bonuses) computed once by an admin at close and shown on the reveal.
    // Bonuses are applied ONLY here, so hidden specials stay secret during play
    // and produce the end-of-game reshuffle. Public read; admin-only write.
    match /results/{edition} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // staff/{edition} : the PUBLIC staff uid list, so the projector (/live) can
    // glow staff nodes without reading the admin-only `specials` collection —
    // that keeps /live a login-free, view-only screen. Only PUBLIC specials go
    // here; hidden specials are NEVER listed (secrecy). Admin-only write.
    match /staff/{edition} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /admins/{uid} {
      // Single-doc read is open to any signed-in user: registration via an
      // invite must check whether the issuer is a host (admins/{issuedBy}), and
      // that issuer is not the registrant. Docs are empty and keyed by an opaque
      // uid, so exposing existence-by-id is low-risk. Enumeration stays
      // admin-only so the full admin roster can't be listed.
      allow get: if isSignedIn();
      allow list: if isAdmin();
      allow write: if false; // set via console / privileged tooling only
    }
  }
}
